# ==============================================================================
# Couchbase Capella + Kafka + OpenTelemetry Demo Project Configuration
# Copy this file to .env and fill in the values before running the deploy scripts.
# ==============================================================================

# ------------------------------------------------------------------------------
# Azure Configuration
# ------------------------------------------------------------------------------
# Azure Subscription ID where the VM and resources will be created
AZURE_SUBSCRIPTION_ID="your-azure-subscription-id"

# Azure location/region (e.g., eastus, westus2, westeurope)
AZURE_LOCATION="eastus"

# Prefix for naming resources (e.g., demo-cb-otel)
RESOURCE_PREFIX="couchbase-otel-kafka-demo"

# VM Size (e.g., Standard_D4s_v5 - recommended for running OTel demo + Redpanda + Connect)
AZURE_VM_SIZE="Standard_D4s_v5"

# Admin username for the Linux VM
VM_ADMIN_USERNAME="azureuser"

# GitHub repository URL to clone on the VM (change this to your fork/repo)
GITHUB_REPO_URL="https://github.com/cb-davidelliott/demo-couchbase-kafka-otel.git"


# ------------------------------------------------------------------------------
# Couchbase Capella Configuration
# ------------------------------------------------------------------------------
# Couchbase Connection String (e.g., couchbases://cb.xxxxxxxxxxx.dp.cloud.couchbase.com)
COUCHBASE_CONN_STR="couchbases://your-capella-endpoint"

# Hostname used by Kafka Connect's Couchbase connector.
# If omitted, deploy scripts derive it from COUCHBASE_CONN_STR.
COUCHBASE_SEED_NODES=""

# Database user with read/write permissions to the demo bucket
COUCHBASE_USERNAME="demo_user"
COUCHBASE_PASSWORD="your-secure-password"

# Bucket and scope used by the Kafka connector and UI.
# Create the bucket, scope, and required collections before deploying.
# See docs/01_DEPLOYMENT.md for copy/paste SQL++ schema setup commands.
COUCHBASE_BUCKET="demo"
COUCHBASE_SCOPE="app360"

# ------------------------------------------------------------------------------
# Demo Load Controls
# ------------------------------------------------------------------------------
# These control the business event generator at deploy time.
#
# Profiles:
#   demo  - realistic, lower-volume behavior with OTel calls enabled by default.
#   load  - high-volume business document generation with OTel calls disabled by default.
#
# Each generated business event usually writes:
#   - 1 order document
#   - 1 payment document
#   - 1 shipment document
#   - sometimes 1 customer document
#   - sometimes 1 support ticket document
#   - metric documents if enabled
#   - incident summary updates at a configurable interval
#
# Defaults are intentionally conservative for a stable first demo.
GENERATOR_PROFILE="demo"
GENERATOR_INTERVAL_SECONDS="5.0"
GENERATOR_EVENTS_PER_BATCH="1"
GENERATOR_ENABLE_OTEL_CALLS="true"
GENERATOR_NEW_CUSTOMER_PROBABILITY="0.2"
GENERATOR_TICKET_PROBABILITY="0.25"
GENERATOR_ENABLE_METRICS="true"
GENERATOR_ENABLE_INCIDENT_UPDATES="true"
GENERATOR_UNIQUE_METRIC_DOCS="false"
GENERATOR_LOG_EVERY_N_EVENTS="1"
GENERATOR_FLUSH_EVERY_N_EVENTS=""
GENERATOR_INCIDENT_UPDATE_EVERY_N_EVENTS="1"
GENERATOR_PRODUCER_LINGER_MS="5"
GENERATOR_PRODUCER_BATCH_NUM_MESSAGES="10000"
GENERATOR_PRODUCER_QUEUE_MAX_MESSAGES="100000"
GENERATOR_PRODUCER_COMPRESSION="lz4"

# Incident scenario controls:
GENERATOR_SCENARIO="payment_outage"
# GENERATOR_INCIDENT_ID="INC-DEMO-001"
# GENERATOR_RANDOM_SEED="demo-001"

# Example profiles:
#
# Realistic incident demo with OTel traces/logs:
# GENERATOR_PROFILE="demo"
# GENERATOR_INTERVAL_SECONDS="1"
# GENERATOR_EVENTS_PER_BATCH="10"
# GENERATOR_ENABLE_OTEL_CALLS="true"
# GENERATOR_NEW_CUSTOMER_PROBABILITY="0.5"
# GENERATOR_TICKET_PROBABILITY="0.5"
#
# High-volume business document loading:
# GENERATOR_PROFILE="load"
# GENERATOR_INTERVAL_SECONDS="0"
# GENERATOR_EVENTS_PER_BATCH="5000"
# GENERATOR_ENABLE_OTEL_CALLS="false"
# GENERATOR_NEW_CUSTOMER_PROBABILITY="1.0"
# GENERATOR_TICKET_PROBABILITY="1.0"
# GENERATOR_ENABLE_METRICS="true"
# GENERATOR_ENABLE_INCIDENT_UPDATES="true"
# GENERATOR_UNIQUE_METRIC_DOCS="true"
# GENERATOR_LOG_EVERY_N_EVENTS="10000"
# GENERATOR_FLUSH_EVERY_N_EVENTS="50000"
# GENERATOR_INCIDENT_UPDATE_EVERY_N_EVENTS="1000"
#
# Very high-volume local generation:
# GENERATOR_PROFILE="load"
# GENERATOR_INTERVAL_SECONDS="0"
# GENERATOR_EVENTS_PER_BATCH="10000"
# GENERATOR_LOG_EVERY_N_EVENTS="25000"
# GENERATOR_FLUSH_EVERY_N_EVENTS="100000"
# GENERATOR_INCIDENT_UPDATE_EVERY_N_EVENTS="5000"
# GENERATOR_PRODUCER_BATCH_NUM_MESSAGES="100000"
# GENERATOR_PRODUCER_QUEUE_MAX_MESSAGES="1000000"
#
# Multi-replica generation:
# - Remove incident update contention by setting this to false when running
#   multiple generator replicas for pure volume loading:
#   GENERATOR_ENABLE_INCIDENT_UPDATES="false"
#
# These are generator targets, not guaranteed end-to-end Couchbase ingest rates.
# Actual throughput depends on VM size, Redpanda, Kafka topic partitions,
# Kafka Connect tasks, connector flush behavior, network, and Capella capacity.
#
# Notes:
# - Set GENERATOR_ENABLE_OTEL_CALLS="true" when you want realistic traces/logs.
#   That path is slower because every event calls the OTel demo service.
# - Set GENERATOR_ENABLE_OTEL_CALLS="false" for high-volume business document
#   loading. Orders/customers/tickets still get synthetic trace IDs.
# - GENERATOR_NEW_CUSTOMER_PROBABILITY is a value from 0.0 to 1.0.
#   "0.0" means never create new customers after warmup, "0.2" means about
#   20% of events create a new customer, "0.5" means about half, and "1.0"
#   means every event creates a new customer instead of reusing customers.
# - Set GENERATOR_TICKET_PROBABILITY="1.0" to create a support ticket doc for
#   every event.
# - Set GENERATOR_ENABLE_METRICS="false" if you want maximum order/payment/shipment
#   volume and do not need metric documents for that run.
# - Set GENERATOR_ENABLE_INCIDENT_UPDATES="false" for multi-replica load runs
#   when you do not want each replica rewriting the same incident summary doc.
# - Set GENERATOR_UNIQUE_METRIC_DOCS="true" to create metric documents with
#   unique Kafka keys. Otherwise metrics intentionally update aggregate docs.
# - GENERATOR_LOG_EVERY_N_EVENTS controls progress logging. Use a large value for
#   load generation to avoid log overhead.
# - GENERATOR_FLUSH_EVERY_N_EVENTS controls how often the Kafka producer waits for
#   delivery acknowledgements. Blank means profile default. Use larger values for
#   throughput; use smaller values for easier debugging.
# - GENERATOR_INCIDENT_UPDATE_EVERY_N_EVENTS controls how often the incident
#   summary document is updated during a run. Use larger values for load generation.
# - Producer knobs are advanced settings for batching and local queue size.
# - GENERATOR_ENTERPRISE_ACCOUNT_COUNT controls how many enterprise account
#   reference documents are seeded when the generator starts. The default is 30.
# - GENERATOR_SCENARIO controls the incident story generated with the data.
#   Supported values:
#     normal              SEV4 baseline traffic; CREATED orders; low failures
#     payment_outage      SEV2 checkout/payment latency; PAYMENT_REVIEW orders
#     regional_latency    SEV2 regional checkout/shipping latency; DELAYED orders
#     inventory_mismatch  SEV2 inventory reservation failures; INVENTORY_REVIEW orders
#     vip_customer_impact SEV1 high-value account impact; ESCALATED orders
#     recovery            SEV3 payment incident recovery; RECOVERING orders
#   Hyphenated or spaced names are accepted too, for example
#   "regional-latency" or "vip customer impact".
# - GENERATOR_INCIDENT_ID gives the active scenario a stable incident ID for
#   repeatable demos and easy UI/search references.
# - GENERATOR_RANDOM_SEED makes generated reference data more repeatable across
#   fresh deploys that use the same scenario and account count.
